{
  "name": "tendershield",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "build": "corepack pnpm -r build",
    "contracts:compile": "corepack pnpm --filter @tendershield/contracts compile",
    "contracts:test": "corepack pnpm --filter @tendershield/contracts test",
    "contracts:deploy:local": "corepack pnpm --filter @tendershield/contracts deploy:local",
    "contracts:deploy:sepolia": "corepack pnpm --filter @tendershield/contracts deploy:sepolia",
    "web:clean": "corepack pnpm --filter @tendershield/web clean",
    "web:dev": "corepack pnpm --filter @tendershield/web dev",
    "web:build": "corepack pnpm --filter @tendershield/web build"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
