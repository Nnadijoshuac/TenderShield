{
  "name": "@tendershield/contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rimraf ./artifacts ./cache ./coverage ./types ./dist",
    "compile": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat compile",
    "postcompile": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat typechain",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.ts --network hardhat",
    "deploy:running": "hardhat run scripts/deploy-and-save.ts --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "build": "npm run compile"
  },
  "dependencies": {
    "@fhevm/mock-utils": "^0.4.2",
    "@fhevm/solidity": "^0.11.1",
    "@openzeppelin/contracts": "^5.6.1",
    "encrypted-types": "^0.0.4",
    "fhevm": "^0.4.0",
    "hardhat": "^2.19.0"
  },
  "devDependencies": {
    "@fhevm/hardhat-plugin": "^0.4.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.30",
    "@zama-fhe/relayer-sdk": "0.4.1",
    "chai": "^4.5.0",
    "cross-env": "^7.0.3",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6",
    "hardhat-deploy": "^0.11.45",
    "rimraf": "^6.1.3",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  }
}